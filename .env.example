# Copy to .env and customize for your environment.

LISTEN_ADDR=:8080
DATABASE_PATH=./storage/llm_guard.db
INITIAL_API_KEYS=dev-key-1
CLASSIFIER_PATH=./models/classifier_v1.json
GEOIP_DB_PATH=./storage/GeoLite2-Country.mmdb
COUNTRY_BLACKLIST=
DOMAIN_BLACKLIST_PATH=./config/domain_blacklist.txt
INTERNAL_DESTINATION_ALLOWLIST_PATH=./config/internal_destination_allowlist.txt
FAIL_CLOSED=true
TRUST_PROXY_HEADERS=true
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
RISK_THRESHOLD=0.70
MAX_BODY_BYTES=1048576
